{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(diff:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(realpath:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(rm -rf /private/var/folders/*)",
      "Bash(rm -rf /tmp/*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(ln -s:*)",
      "Bash(octopus:*)",
      "Bash(octo:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(python -m:*)",
      "Bash(python3 -m:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python -m octopus:*)",
      "Bash(python3 -m octopus:*)",
      "Bash(python -c:*)",
      "Bash(python3 -c:*)",
      "Bash(pip install -e .)",
      "Bash(pip install -e cli/)",
      "Bash(pip install -e .[dev])",
      "Bash(pip install -e cli/[dev])",
      "Bash(pip show:*)",
      "Bash(pip list:*)",
      "Bash(pipx install octopus-cli)",
      "Bash(pipx upgrade octopus-cli)",
      "Bash(pipx list)",
      "Bash(ruff:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(mktemp:*)",
      "Bash(TMPDIR=*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf /Users/*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
