{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "octopus where 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "octopus session show 2>/dev/null | grep -q '^title:' && echo '💡 Active octopus session — consider /octopus:log to capture what happened.' || true"
          }
        ]
      }
    ]
  }
}
